<%- include('../partials/header') %>

<div class="container my-4">
    <h2 class="mb-4">User Directory</h2>
    
    <div class="alert alert-info">
        <p class="mb-0">
            This page is a demo built using Node.js, Express.js, and EJS templates.
            It demonstrates a list/view design pattern and pulls data from a JSON file.
            The pictures and content were generated by third-party APIs and do not represent actual identities.
        </p>
    </div>

    
    <table class="table table-hover table-striped">
        <thead class="thead-dark">
            <tr>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Email</th>
            </tr>
        </thead>
        <tbody>
            <% users.forEach(function(user){ %>
                <tr>
                     <td><a href="/users/view/<%= user.id %>"><%= user.first_name %></a></td>
                     <td><%= user.last_name %></td>
                     <td><%= user.email %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>
</div>

<%- include('../partials/footer') %>
